{
  "expo": {
    "name": "SkillSwap",
    "slug": "SkillSwap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skillswap",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#141022",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141022"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#141022",
      "infoPlist": {
        "NSFaceIDUsageDescription": "SkillSwap uses Face ID so you can sign in quickly and securely without entering your password.",
        "NSCameraUsageDescription": "SkillSwap uses your camera for video calls with swap partners.",
        "NSMicrophoneUsageDescription": "SkillSwap uses your microphone for voice and video calls with swap partners."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#141022"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": ["CAMERA", "RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141022",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SkillSwap to access your photos to set a profile picture.",
          "cameraPermission": "Allow SkillSwap to use your camera for a profile photo."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
